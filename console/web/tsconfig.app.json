{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@foxl/code/*": ["src/vendor/code/*"],
      "@foxl/code": ["src/vendor/code/index.ts"],
      "@foxl/ui": ["src/vendor/ui/index.ts"],
      "@foxl/ui/*": ["src/vendor/ui/*"],
      "@foxl/types": ["src/vendor/types/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
